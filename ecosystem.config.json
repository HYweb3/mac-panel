{
  "apps": [
    {
      "name": "mac-panel-backend",
      "script": "backend/dist/app.js",
      "cwd": "/Users/www1/Desktop/claude/mac-panel",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "production",
        "PORT": "3001"
      },
      "error_file": "logs/backend-error.log",
      "out_file": "logs/backend-out.log",
      "log_file": "logs/backend-combined.log",
      "time": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s"
    },
    {
      "name": "mac-panel-frontend",
      "script": "npm",
      "args": "run dev",
      "cwd": "/Users/www1/Desktop/claude/mac-panel/frontend",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "1G",
      "env": {
        "NODE_ENV": "development"
      },
      "error_file": "logs/frontend-error.log",
      "out_file": "logs/frontend-out.log",
      "log_file": "logs/frontend-combined.log",
      "time": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s",
      "kill_timeout": 5000
    }
  ]
}
